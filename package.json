{
  "name": "soyorin-fluid",
  "version": "0.1.1",
  "description": "A lightweight WebGL water ripple effect library.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/waterRipple.d.ts",
  "exports": {
    ".": {
      "types": "./dist/waterRipple.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "npm run build:types && vite build",
    "build:types": "vue-tsc -p tsconfig.lib.json",
    "build:extension": "vite build --config vite.extension.config.ts",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "webgl",
    "water",
    "ripple",
    "canvas",
    "effect"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
